{
	"table_name": "user_files",
	"description": "Metadata for files uploaded by users and stored on HDD01.",
	"columns": [
		{
			"name": "id",
			"type": "uuid",
			"primary_key": true,
			"default": "gen_random_uuid()",
			"nullable": false
		},
		{
			"name": "user_id",
			"type": "uuid",
			"nullable": false,
			"index": true,
			"foreign_key": {
				"table": "users",
				"column": "id",
				"on_delete": "cascade"
			}
		},
		{
			"name": "original_name",
			"type": "varchar",
			"length": 255,
			"nullable": false
		},
		{
			"name": "stored_name",
			"type": "varchar",
			"length": 64,
			"nullable": false,
			"unique": true
		},
		{
			"name": "mime_type",
			"type": "varchar",
			"length": 128,
			"nullable": true
		},
		{
			"name": "size_bytes",
			"type": "bigint",
			"nullable": false
		},
		{
			"name": "download_count",
			"type": "int",
			"nullable": false,
			"default": 0
		},
		{
			"name": "created_at",
			"type": "timestamptz",
			"nullable": false,
			"default": "now()"
		},
		{
			"name": "updated_at",
			"type": "timestamptz",
			"nullable": false,
			"default": "now()"
		}
	],
	"indexes": [
		{
			"name": "user_files_user_id_idx",
			"columns": ["user_id"],
			"unique": false
		}
	]
}
